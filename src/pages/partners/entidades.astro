---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import HeadTitle from "../../components/HeadTitle.astro";
import EntitiesData from "../../../public/json/entities.json";

interface Entity {
  name: string;
  logo?: string;
  whatTheyDo?: string;
  collaboration?: string;
  url?: string;
}

const entities = (EntitiesData.entities || []) as Entity[];
---

<Layout title="Partners | Entidades TARS">
  <Header />
  <HeadTitle
    icon="/img/news.svg"
    text="Entidades"
    description="Instituciones y organizaciones que forman parte de nuestro ecosistema."
  />

  <main class="max-w-[1200px] mx-auto px-4 sm:px-10 pb-16">
    <section class="grid grid-cols-1 gap-6">
      {
        entities.map((entity) => (
          <article class="group rounded-xl border border-zinc-800/40 bg-[#181818] p-6 hover:-translate-y-1 transition-all">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-5">
              <div>
                <h2 class="text-2xl font-bold text-white">{entity.name}</h2>
              </div>
              {
                entity.logo && (
                  <img
                    src={entity.logo}
                    alt={`Logo ${entity.name}`}
                    class="w-full max-w-[240px] h-auto object-contain rounded-md border border-zinc-700/40 bg-[#121212] p-2"
                  />
                )
              }
            </div>
            <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="rounded-lg border border-zinc-800/60 bg-black/20 p-4">
                <h3 class="text-blue-400 text-sm uppercase tracking-wide">
                  Qué hacen
                </h3>
                <p class="mt-2 text-white/75 text-sm leading-relaxed">
                  {entity.whatTheyDo || "Información no disponible."}
                </p>
              </div>
              <div class="rounded-lg border border-zinc-800/60 bg-black/20 p-4">
                <h3 class="text-blue-400 text-sm uppercase tracking-wide">
                  Cómo colaboramos
                </h3>
                <p class="mt-2 text-white/75 text-sm leading-relaxed">
                  {entity.collaboration || "Información no disponible."}
                </p>
              </div>
            </div>
            {entity.url && (
              <a
                href={entity.url}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-5 inline-flex items-center gap-2 text-blue-400 hover:text-blue-300"
              >
                Visitar sitio
                <img
                  src="https://unpkg.com/pixelarticons@1.8.1/svg/external-link.svg"
                  alt="Abrir"
                  class="w-5 h-5 invert"
                />
              </a>
            )}
          </article>
        ))
      }
    </section>
  </main>

  <Footer />
</Layout>
