---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import HeadTitle from "../../components/HeadTitle.astro";
import Button from "../../components/Button.astro";
import WorkshopsData from "../../../public/json/workshops.json";

interface WorkshopPartner {
  name: string;
  role: string;
  logo?: string;
  url?: string;
}

interface Workshop {
  slug: string;
  title: string;
  category: string;
  status: string;
  date?: string;
  partner?: string;
  location?: string;
  schedule?: string;
  summary: string;
  heroImage: string;
  partners?: WorkshopPartner[];
  sponsors?: WorkshopPartner[];
}

const workshops = (WorkshopsData.workshops || []) as Workshop[];
const featuredMessage = WorkshopsData.featuredMessage;
const contactUrl = WorkshopsData.contactUrl;
---

<Layout
  title="Talleres | TARS UPV"
  description="Talleres y formaciones organizadas por TARS para compartir conocimientos tecnicos y practicos."
>
  <Header />
  <HeadTitle
    icon="/img/news.svg"
    text="Talleres"
    description="Las sesiones y formaciones que vamos organizando desde TARS."
  />

  <main class="mx-auto flex max-w-[1400px] flex-col gap-12 px-4 pb-16 sm:px-10">
    <section class="rounded-2xl border border-zinc-800/40 bg-[radial-gradient(circle_at_top_left,_rgba(59,130,246,0.14),_transparent_35%),linear-gradient(135deg,_#171717,_#0e0e0e)] p-6 sm:p-10">
      <div class="flex flex-col gap-4">
        <span class="inline-flex w-fit rounded-full border border-blue-400/20 bg-blue-500/10 px-3 py-1 text-xs uppercase tracking-[0.25em] text-blue-300">
          Formacion TARS
        </span>
        <h2 class="max-w-3xl text-3xl font-bold text-white sm:text-4xl">
          Nuestros talleres y eventos
        </h2>
        <p class="max-w-3xl text-base leading-relaxed text-white/70">
          No solo nos dedicamos a competir, sino que tambien estamos muy interesados en difundir la robotica competitiva a los estudiantes de la UPV. Esto lo hacemos mediante la organizacion de talleres con el objetivo de que los alumnos se acerquen al diseno de un robot realmente competitivo y de alto nivel.
        </p>
      </div>
    </section>

    <section class="grid grid-cols-1 gap-6">
      {
        workshops.map((workshop) => (
          <article class="group overflow-hidden rounded-2xl border border-zinc-800/50 bg-[#141414] transition-all hover:-translate-y-1 hover:border-blue-500/35 lg:grid lg:grid-cols-[360px_1fr]">
            <div class="relative aspect-[16/10] overflow-hidden lg:aspect-auto lg:h-full">
              <img
                src={workshop.heroImage}
                alt={workshop.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#111111] via-[#111111]/30 to-transparent" />
              <div class="absolute left-4 top-4 flex flex-wrap gap-2">
                <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-white backdrop-blur-sm">
                  {workshop.category}
                </span>
                <span class="rounded-full bg-emerald-500/15 px-3 py-1 text-xs font-medium text-emerald-300 backdrop-blur-sm">
                  {workshop.status}
                </span>
              </div>
            </div>

            <div class="flex flex-col gap-4 p-6 lg:justify-between">
              <div class="flex flex-wrap gap-2 text-xs text-white/55">
                {workshop.date && (
                  <span class="rounded-full border border-white/10 px-3 py-1">
                    {workshop.date}
                  </span>
                )}
                {workshop.schedule && (
                  <span class="rounded-full border border-white/10 px-3 py-1">
                    {workshop.schedule}
                  </span>
                )}
                {workshop.location && (
                  <span class="rounded-full border border-white/10 px-3 py-1">
                    {workshop.location}
                  </span>
                )}
                {workshop.partner && (
                  <span class="rounded-full border border-white/10 px-3 py-1">
                    En colaboracion con {workshop.partner}
                  </span>
                )}
              </div>

              <div class="flex flex-col gap-3">
                <h3 class="text-2xl font-bold text-white">{workshop.title}</h3>
                <p class="text-sm leading-relaxed text-white/70">
                  {workshop.summary}
                </p>
              </div>

              <div class="flex flex-col gap-2 xl:flex-row xl:items-start xl:gap-3">
                {workshop.partners && workshop.partners.length > 0 && (
                  <div class="flex min-w-0 flex-1 flex-col gap-2">
                    <span class="text-xs uppercase tracking-[0.2em] text-white/40">
                      Colaboran
                    </span>
                    <div class="flex flex-wrap items-center gap-3">
                      {workshop.partners.map((item) => (
                        <div class="flex min-h-12 items-center gap-3 rounded-lg border border-white/10 bg-white/[0.03] px-3 py-2">
                          {item.logo && (
                            <div class="flex h-10 w-14 items-center justify-center rounded-md bg-white p-2">
                              <img
                                src={item.logo}
                                alt={item.name}
                                class="max-h-6 max-w-full object-contain"
                                loading="lazy"
                              />
                            </div>
                          )}
                          <span class="text-sm text-white/75">{item.name}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                {workshop.partners && workshop.partners.length > 0 && workshop.sponsors && workshop.sponsors.length > 0 && (
                  <div class="hidden h-full w-px self-stretch bg-white/10 xl:block" />
                )}

                {workshop.sponsors && workshop.sponsors.length > 0 && (
                  <div class="flex min-w-0 flex-1 flex-col gap-2">
                    <span class="text-xs uppercase tracking-[0.2em] text-white/40">
                      Patrocinan
                    </span>
                    <div class="flex flex-wrap items-center gap-3">
                      {workshop.sponsors.map((item) => (
                        <div class="flex min-h-12 items-center gap-3 rounded-lg border border-white/10 bg-white/[0.03] px-3 py-2">
                          {item.logo ? (
                            <div class="flex h-10 w-14 items-center justify-center rounded-md bg-white p-2">
                              <img
                                src={item.logo}
                                alt={item.name}
                                class="max-h-6 max-w-full object-contain"
                                loading="lazy"
                              />
                            </div>
                          ) : (
                            <span class="text-xs text-white/65">{item.name}</span>
                          )}
                          <span class="text-sm text-white/75">{item.name}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </div>

              <div class="pt-1">
                <a
                  href={`/workshops/${workshop.slug}`}
                  class="inline-flex items-center gap-2 rounded-lg border border-blue-400/30 bg-blue-500/10 px-4 py-2 text-sm font-medium text-blue-200 transition-colors hover:bg-blue-500/20"
                >
                  Ver taller completo
                  <img
                    src="https://unpkg.com/pixelarticons@1.8.1/svg/arrow-right.svg"
                    alt="Arrow right"
                    class="h-4 w-4 invert"
                  />
                </a>
                </div>
            </div>
          </article>
        ))
      }
    </section>
  </main>

  <Footer />
</Layout>
