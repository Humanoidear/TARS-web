---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import InitiativesData from "../../../public/json/internal_initiatives.json";

interface Initiative {
  slug: string;
  title: string;
  description: string;
  longDescription?: string[];
  lead: string;
  leadImage: string;
  image: string;
  gallery?: string[];
  focus: string;
  frequency: string;
  winnerNames?: string;
  winnerUrl?: string;
}

export async function getStaticPaths() {
  const initiatives = (InitiativesData.initiatives || []) as Initiative[];

  return initiatives.map((initiative) => ({
    params: { slug: initiative.slug },
    props: { initiative },
  }));
}

const { initiative } = Astro.props as { initiative: Initiative };
---

<Layout
  title={`${initiative.title} | Iniciativas internas`}
  description={initiative.description}
  image={initiative.image}
>
  <Header />

  <main class="mx-auto flex max-w-[1400px] flex-col gap-10 px-4 pb-16 pt-28 sm:px-10">
    <div>
      <a
        href="/#initiatives"
        class="inline-flex items-center gap-2 rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2 text-sm text-white/75 transition-colors hover:bg-white/[0.06] hover:text-white"
      >
        <img
          src="https://unpkg.com/pixelarticons@1.8.1/svg/arrow-left.svg"
          alt="Volver"
          class="h-4 w-4 invert"
        />
        Volver a iniciativas
      </a>
    </div>

    <section class="overflow-hidden rounded-[28px] border border-zinc-800/50 bg-[#111111]">
      <div class="relative min-h-[360px]">
        <img
          src={initiative.image}
          alt={initiative.title}
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(7,7,7,0.18),rgba(7,7,7,0.9))]" />

        <div class="relative flex min-h-[360px] flex-col justify-end gap-6 p-8 sm:p-12">
          <div class="flex flex-wrap gap-2 text-sm">
            <span class="rounded-full border border-white/15 bg-white/10 px-3 py-1 text-white">
              {initiative.focus}
            </span>
            <span class="rounded-full border border-white/15 bg-white/10 px-3 py-1 text-white">
              {initiative.frequency}
            </span>
          </div>

          <div class="max-w-4xl">
            <p class="mb-3 text-sm uppercase tracking-[0.3em] text-blue-300">
              Iniciativa interna
            </p>
            <h1 class="text-4xl font-bold text-white sm:text-6xl">
              {initiative.title}
            </h1>
            <p class="mt-4 max-w-3xl text-base leading-relaxed text-white/75 sm:text-lg">
              {initiative.description}
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[1.4fr_0.8fr]">
      <article class="rounded-2xl border border-zinc-800/50 bg-[#141414] p-6 sm:p-8">
        <h2 class="text-2xl font-bold text-white">Sobre la iniciativa</h2>
        <div class="mt-6 flex flex-col gap-4 text-white/75">
          {(initiative.longDescription || []).map((paragraph) => (
            <p class="leading-relaxed">{paragraph}</p>
          ))}
        </div>
      </article>

      <aside class="flex flex-col gap-6">
        <div class="rounded-2xl border border-zinc-800/50 bg-[#141414] p-6">
          <h2 class="text-xl font-bold text-white">Responsable</h2>
          <div class="mt-5 flex items-center gap-4 rounded-xl border border-white/8 bg-white/[0.03] p-4">
            <img
              src={initiative.leadImage}
              alt={initiative.lead}
              class="h-16 w-16 rounded-full border border-zinc-700/50 object-cover"
            />
            <div>
              <p class="text-xs uppercase tracking-[0.2em] text-white/40">
                Coordinacion
              </p>
              <p class="mt-1 text-white">{initiative.lead}</p>
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-zinc-800/50 bg-[#141414] p-6">
          <h2 class="text-xl font-bold text-white">Ficha rapida</h2>
          <div class="mt-5 grid gap-3 text-sm text-white/75">
            <div class="rounded-lg border border-white/8 bg-white/[0.03] px-4 py-3">
              <span class="block text-xs uppercase tracking-[0.2em] text-white/40">Area</span>
              <span>{initiative.focus}</span>
            </div>
            <div class="rounded-lg border border-white/8 bg-white/[0.03] px-4 py-3">
              <span class="block text-xs uppercase tracking-[0.2em] text-white/40">Estado</span>
              <span>{initiative.frequency}</span>
            </div>
            {initiative.winnerNames && (
              <div class="rounded-lg border border-white/8 bg-white/[0.03] px-4 py-3">
                <span class="block text-xs uppercase tracking-[0.2em] text-white/40">Ganadores</span>
                <span>{initiative.winnerNames}</span>
                {initiative.winnerUrl && (
                  <a
                    href={initiative.winnerUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-3 inline-flex items-center gap-2 text-sm text-blue-300 transition-colors hover:text-blue-200"
                  >
                    Ver publicacion ganadora
                    <img
                      src="https://unpkg.com/pixelarticons@1.8.1/svg/external-link.svg"
                      alt="Abrir"
                      class="h-4 w-4 invert"
                    />
                  </a>
                )}
              </div>
            )}
          </div>
        </div>
      </aside>
    </section>

    {initiative.gallery && initiative.gallery.length > 0 && (
      <section class="rounded-2xl border border-zinc-800/50 bg-[#141414] p-6 sm:p-8">
        <h2 class="text-2xl font-bold text-white">Galeria</h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {initiative.gallery.map((image, index) => (
            <div class="overflow-hidden rounded-xl border border-white/8 bg-black/20">
              <img
                src={image}
                alt={`${initiative.title} imagen ${index + 1}`}
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>
