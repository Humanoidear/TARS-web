---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import HeadTitle from "../../components/HeadTitle.astro";
import Tutorials from "../../../public/json/tutorials.json";

const workshops = Tutorials.workshops || [];
const teacherCommunity = Tutorials.teacherCommunity;

const getYouTubeVideoId = (url: string) => {
  if (!url) return null;

  try {
    const parsed = new URL(url);
    const host = parsed.hostname.replace("www.", "");
    const path = parsed.pathname;

    if (host === "youtu.be") {
      const id = path.slice(1).split("/")[0];
      return id || null;
    }

    if (host === "youtube.com" || host === "m.youtube.com") {
      if (path === "/watch") {
        return parsed.searchParams.get("v");
      }

      if (path.startsWith("/shorts/")) {
        return path.split("/")[2] || null;
      }
    }

    return null;
  } catch {
    return null;
  }
};
---

<Layout
  title="Talleres ONU | TARS UPV"
  description="Tutoriales y recursos de TARS UPV para la competicion de la ONU."
>
  <Header />
  <HeadTitle
    icon="/img/youtube.svg"
    text="Talleres ONU"
    description="Tutoriales y recursos para preparar la competicion."
  />

  <main class="-translate-y-[30px] px-6 sm:px-36 pb-16">
    <section class="rounded-2xl border border-blue-400/20 bg-[linear-gradient(135deg,_rgba(15,23,42,0.98),_rgba(10,10,10,0.98))] p-6 sm:p-8">
      <div class="flex flex-col gap-6">
        <div class="w-full text-center">
          <p class="text-xs uppercase tracking-[0.28em] text-blue-300">
            Colaboracion activa
          </p>
          <p class="mt-3 text-base leading-relaxed text-white/75 sm:text-lg">
            Esta colaboracion entre TARS Robotics UPV y el United Nations Global Service Center en Valencia tiene como objetivo apoyar a la comunidad de la UN Robotics Competition mediante tutoriales de hardware y software para ayudar a docentes y estudiantes a disenar y construir su propio robot, ademas de ofrecer acceso a un grupo de WhatsApp donde resolver dudas y recibir apoyo directo de nuestro equipo.
          </p>
        </div>
      </div>
    </section>

    <section class="mt-6 overflow-hidden rounded-2xl border border-cyan-400/20 bg-[radial-gradient(circle_at_top_right,_rgba(34,211,238,0.18),_transparent_30%),linear-gradient(135deg,_rgba(8,20,28,0.98),_rgba(10,10,10,0.98))] p-6 sm:p-8">
      <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div class="max-w-3xl">
          <p class="text-xs uppercase tracking-[0.28em] text-cyan-300">
            Recursos para docentes
          </p>
          <h2 class="mt-3 text-3xl font-bold text-white sm:text-4xl">
            Descarga la libreria preparada por TARS
          </h2>
          <p class="mt-4 text-base leading-relaxed text-white/75 sm:text-lg">
            Hemos preparado una libreria lista para usar en clase y en la competicion. Puedes descargar el paquete mas reciente desde GitHub e incorporarlo directamente a vuestros proyectos de UN Robotics.
          </p>
        </div>

        <a
          href="https://github.com/UPV-TARS/UN-Robotics/releases/latest/download/TARS.zip"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-fit items-center justify-center gap-2 rounded-xl bg-cyan-400 px-5 py-3 font-semibold text-[#06131a] transition-colors hover:bg-cyan-300 md:shrink-0"
        >
          Descargar libreria
          <img
            src="https://unpkg.com/pixelarticons@1.8.1/svg/download.svg"
            alt="Descargar"
            class="h-5 w-5"
          />
        </a>
      </div>
    </section>

    <section
      class="mt-6 w-full rounded-2xl border border-zinc-800/40 bg-gradient-to-br from-[#1a1a1a] to-[#121212] p-6 sm:p-10"
    >
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
          <span class="inline-block text-blue-500 text-sm font-medium mb-2">
            FORMACION
          </span>
          <h2 class="text-white text-3xl sm:text-4xl font-bold mb-4">
            Accede a los tutoriales oficiales
          </h2>
          <p class="text-white/70 max-w-3xl">
            Esta seccion centraliza los talleres para la competicion de la ONU.
            Puedes verlos en nuestro canal y revisar cada bloque segun nivel.
          </p>
        </div>

        <a
          href={Tutorials.featuredChannelUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="h-fit inline-flex items-center gap-2 rounded-md bg-red-600 px-4 py-3 text-white font-semibold hover:bg-red-500 transition-colors md:shrink-0"
        >
          Ver canal de YouTube
          <img
            src="https://unpkg.com/pixelarticons@1.8.1/svg/external-link.svg"
            alt="Abrir"
            class="w-5 h-5 invert"
          />
        </a>
      </div>
    </section>

    <section class="mt-10 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      {
        workshops.map((workshop) => (
          <article class="group rounded-xl border border-zinc-800/40 bg-[#171717] p-6 hover:-translate-y-1 transition-all">
            <div class="flex items-center justify-between gap-3">
              <span class="text-xs text-blue-400 bg-blue-500/10 rounded-full px-3 py-1">
                {workshop.level}
              </span>
              <span class="text-xs text-white/60">{workshop.duration}</span>
            </div>

            <h3 class="mt-4 text-white text-2xl font-bold leading-tight">
              {workshop.title}
            </h3>
            <p class="mt-3 text-white/70 line-clamp-3">{workshop.description}</p>

            <div class="mt-4 rounded-lg overflow-hidden border border-zinc-700/60 bg-black/30">
              {
                getYouTubeVideoId(workshop.youtubeUrl) ? (
                  <iframe
                    class="w-full aspect-video"
                    src={`https://www.youtube-nocookie.com/embed/${getYouTubeVideoId(workshop.youtubeUrl)}`}
                    title={`Snippet ${workshop.title}`}
                    loading="lazy"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                  />
                ) : (
                  <div class="w-full aspect-video flex flex-col items-center justify-center gap-2 text-center px-4">
                    <img
                      src="/img/youtube.svg"
                      alt="YouTube"
                      class="w-8 h-8 invert opacity-80"
                    />
                    <p class="text-white/80 text-sm">
                      AÃ±ade una URL directa de video para ver el snippet aqui.
                    </p>
                  </div>
                )
              }
            </div>

            <div class="mt-6 flex items-center justify-between">
              <span
                class:list={[
                  "text-xs rounded-full px-3 py-1",
                  workshop.status === "Disponible"
                    ? "bg-emerald-500/15 text-emerald-300"
                    : "bg-amber-500/15 text-amber-300",
                ]}
              >
                {workshop.status}
              </span>

              <a
                href={workshop.youtubeUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-white/80 hover:text-white inline-flex items-center gap-1"
              >
                Ver tutorial
                <img
                  src="https://unpkg.com/pixelarticons@1.8.1/svg/arrow-right.svg"
                  alt="Arrow right"
                  class="w-5 h-5 invert"
                />
              </a>
            </div>
          </article>
        ))
      }
    </section>

    <section class="mt-14 overflow-hidden rounded-2xl border border-emerald-400/20 bg-[radial-gradient(circle_at_top_left,_rgba(16,185,129,0.18),_transparent_35%),linear-gradient(135deg,_rgba(9,18,18,0.98),_rgba(9,9,11,0.96))]">
      <div class="grid gap-8 p-6 sm:p-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
        <div>
          <span class="inline-flex rounded-full border border-emerald-400/20 bg-emerald-500/10 px-3 py-1 text-xs font-medium uppercase tracking-[0.2em] text-emerald-300">
            Docentes UN Robotics
          </span>
          <h2 class="mt-4 max-w-3xl text-3xl font-bold text-white sm:text-4xl">
            {teacherCommunity.title}
          </h2>
          <p class="mt-4 max-w-3xl text-base leading-relaxed text-white/75">
            {teacherCommunity.description}
          </p>

          <div class="mt-6 grid gap-3 sm:grid-cols-3">
            <div class="rounded-xl border border-white/10 bg-white/[0.04] p-4">
              <p class="text-sm font-semibold text-white">Resuelve dudas rapidamente</p>
              <p class="mt-2 text-sm leading-relaxed text-white/60">
                Pregunta sobre normativa, montaje, estrategia o entregables y recibe ayuda directa de otros docentes y del equipo de TARS Robotics UPV.
              </p>
            </div>
            <div class="rounded-xl border border-white/10 bg-white/[0.04] p-4">
              <p class="text-sm font-semibold text-white">Toda la informacion en un solo lugar</p>
              <p class="mt-2 text-sm leading-relaxed text-white/60">
                Comparte recursos, descubre recomendaciones de TARS Robotics UPV y mantente al dia con avisos importantes de la competicion.
              </p>
            </div>
            <div class="rounded-xl border border-white/10 bg-white/[0.04] p-4">
              <p class="text-sm font-semibold text-white">Acompanamiento durante toda la competicion</p>
              <p class="mt-2 text-sm leading-relaxed text-white/60">
                Un canal gestionado por TARS Robotics UPV para docentes que quieren guiar mejor a su equipo en cada fase del proyecto.
              </p>
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-white/10 bg-black/25 p-6 shadow-[0_20px_60px_rgba(0,0,0,0.3)]">
          <div class="rounded-2xl border border-emerald-400/20 bg-emerald-500/10 p-5">
            <p class="text-sm uppercase tracking-[0.22em] text-emerald-300">
              Accede a la comunidad
            </p>
            <p class="mt-3 text-lg font-semibold text-white">
              Rellena este formulario en menos de un minuto y te daremos acceso directo a la comunidad de whatsapp
            </p>
            <div class="mt-3 text-sm leading-relaxed text-white/65">
              <p class="font-medium text-white/80">Perfecto para:</p>
              <p class="mt-2">Resolver incidencias con apoyo de TARS Robotics UPV</p>
              <p>Consultar detalles de la competicion con nuestro equipo</p>
              <p>Contactar directamente con soporte de TARS Robotics UPV</p>
            </div>
          </div>

          <a
            href={teacherCommunity.url}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-emerald-500 px-4 py-3 text-center font-semibold text-[#04110d] transition-colors hover:bg-emerald-400"
          >
            {teacherCommunity.ctaLabel}
            <img
              src="https://unpkg.com/pixelarticons@1.8.1/svg/external-link.svg"
              alt="Abrir"
              class="h-5 w-5"
            />
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
